{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ProStation",
  "mainBinaryName": "ProStation",
  "version": "0.1.6",
  "identifier": "com.xueleikong.prostation",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ProStation",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "bundleName": "ProStation",
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM0RTc2NDM4Q0I0Qjk2NDcKUldSSGxrdkxPR1RueE80b1lmdTF1aGNJRE1BWEp6SHRDcEVEdmVBNW5vaWtxenZhcmpYcWI4a2YK",
      "endpoints": [
        "https://github.com/brucekong/ProManage/releases/latest/download/latest.json"
      ]
    }
  }
}
